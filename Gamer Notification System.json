{
  "name": "Gamer Notification System",
  "nodes": [
    {
      "parameters": {
        "content": "## 🎮 Gamer Notification System\n\nThis workflow automatically fetches gaming news every hour, uses AI to classify and summarize articles, then sends important updates to Telegram.",
        "height": 200,
        "width": 400,
        "color": 5
      },
      "id": "7043793a-3974-4f71-a36d-047c90c1e8ca",
      "name": "Sticky Note 3f913ee1",
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [
        112,
        112
      ]
    },
    {
      "parameters": {
        "content": "**Step 1: Schedule**\nRuns every 1 hour using cron expression",
        "color": 2
      },
      "id": "9c46bbdf-a9f8-4c0a-baab-fb3e03abdfbd",
      "name": "Sticky Note 389e2a8a",
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [
        112,
        352
      ]
    },
    {
      "parameters": {
        "content": "**Step 2: Fetch News**\nGets latest gaming news from Google News RSS feed",
        "color": 2
      },
      "id": "93bcec33-aa71-482b-9694-2c0e946f7f08",
      "name": "Sticky Note 9c556789",
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [
        112,
        560
      ]
    },
    {
      "parameters": {
        "content": "**Step 3: Process Each Article**\nLoops through each news item individually",
        "color": 2
      },
      "id": "c8480513-d98f-4e59-9bfc-5d0db33bab53",
      "name": "Sticky Note c003ec13",
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [
        112,
        752
      ]
    },
    {
      "parameters": {
        "content": "**Step 4: AI Classification**\nAI reads title, generates summary, and classifies as Update/Event/Ignore",
        "color": 3
      },
      "id": "6a9d696b-257c-46ff-9787-2d1ccb63f52c",
      "name": "Sticky Note 1bec419e",
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [
        608,
        352
      ]
    },
    {
      "parameters": {
        "content": "**Step 5: Filter**\nOnly continue if category is NOT \"Ignore\"",
        "color": 3
      },
      "id": "a612f500-60b3-4344-8751-88e51f87fcba",
      "name": "Sticky Note 7f23d363",
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [
        680,
        776
      ]
    },
    {
      "parameters": {
        "content": "**Step 6: Send Alert**\nSends formatted notification to Telegram",
        "color": 4
      },
      "id": "60012c95-ffe7-4301-91ae-29d5789d74e9",
      "name": "Sticky Note 9546c9fa",
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [
        1104,
        352
      ]
    },
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "0 * * * *"
            }
          ]
        }
      },
      "id": "b3f392f2-1fe3-4e58-86ae-4a8281382430",
      "name": "Every 1 Hour",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.3,
      "position": [
        304,
        776
      ]
    },
    {
      "parameters": {
        "url": "https://api.rss2json.com/v1/api.json?rss_url=https://news.google.com/rss/search?q=gaming",
        "options": {
          "response": {
            "response": {
              "responseFormat": "json"
            }
          }
        }
      },
      "id": "17af4a8f-facb-458d-8ade-f7af499e408d",
      "name": "Fetch Gaming News",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        528,
        776
      ]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "1",
              "name": "items",
              "value": "={{ $json.items }}",
              "type": "array"
            }
          ]
        },
        "options": {
          "dotNotation": true
        }
      },
      "id": "d5134c3d-6a49-4eed-8b33-90e943c5d236",
      "name": "Extract News Items",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
