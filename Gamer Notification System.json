              "type": "string"
            },
            {
              "id": "2",
              "name": "timestamp",
              "value": "={{ $now.toISO() }}",
              "type": "string"
            }
          ]
        },
        "options": {
          "dotNotation": true
        }
      },
      "id": "6d99f272-cc78-45c9-85a7-245001180cd3",
      "name": "All Articles Processed",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
        1488,
        704
      ]
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=Analyze this gaming news:\n\nTitle: {{$json[\"title\"]}}\n\nReturn ONLY valid JSON (no extra text):\n\n{\n  \"summary\": \"one line summary\",\n  \"category\": \"Update\"\n}",
        "hasOutputParser": true,
        "options": {
          "systemMessage": "You are a gaming news classifier. Analyze news titles and provide structured output with summary and category.",
          "maxIterations": 3
        }
      },
      "id": "b66999de-d5b3-44cd-9a90-128d32902b80",
      "name": "AI News Classifier",
      "type": "@n8n/n8n-nodes-langchain.agent",
